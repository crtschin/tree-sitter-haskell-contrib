default: test

# Run the inline unit tests, parse the dump-stream corpus, and validate that
# injections.scm dispatches every section body to a member grammar that parses
# it (a clean gate modulo documented known gaps).
test: build parse-corpus validate-injections
    tree-sitter test --lib-path result/parser --lang-name ghc_dump

# Parse every harvested GHC dump stream in $GHC_SRC (any IL banner). This only
# checks the banner/body split; `validate-injections` checks the dispatch.
parse-corpus:
    ../test/parse-corpus.sh ghc-dump | tapview

# End-to-end injection check: split each harvested dump stream into its
# banner-delimited sections, classify each with injections.scm's own dispatch
# table, and parse it with the dispatched member grammar (asserting no errors
# beyond the documented known gaps). Needs the member parsers, so build them.
validate-injections:
    nix build ..#tree-sitter-ghc-core -o ../tree-sitter-ghc-core/result
    nix build ..#tree-sitter-ghc-stg -o ../tree-sitter-ghc-stg/result
    nix build ..#tree-sitter-ghc-cmm -o ../tree-sitter-ghc-cmm/result
    ../test/validate-injections.sh | tapview

# Ephemeral coverage check: generate a mixed multi-IL stream with GHC into a
# temp dir, parse it, report errors, tear down (nothing committed; see
# test/gen-corpus.sh).
gen-corpus: build
    ../test/gen-corpus.sh ghc-dump

# Build the grammar via the nix flake (buildGrammar runs generate internally).
build:
    nix build ..#tree-sitter-ghc-dump

# Check grammar for errors without building a result symlink.
check:
    nix build ..#tree-sitter-ghc-dump --no-link

# Format the grammar file (mode: write|check)
fmt mode="write":
    prettier --{{ mode }} grammar.js

# Clean build artifacts
clean:
    rm -rf ghc_dump.so result

# Generate src/parser.c locally (needed by highlight).
generate:
    tree-sitter generate

# Parse a file and print AST
parse file: build
    tree-sitter parse --lib-path result/parser --lang-name ghc_dump {{ file }}

# Show syntax highlighting (resolves injections.scm against the member grammars).
highlight file: generate
    tree-sitter highlight {{ file }}
