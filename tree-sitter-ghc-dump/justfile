lang := "ghc_dump"
slug := "ghc-dump"

# Run recipe lines under bash with pipefail so a gate script's non-zero exit
# propagates through `| tapview` (the script, not tapview, decides pass/fail).
set shell := ["bash", "-o", "pipefail", "-c"]

# Shared build/check/fmt/clean/generate/parse/highlight recipes.
import 'common/recipes.just'

default: test

# Run every suite to completion (queries, dump-stream corpus, injection dispatch,
# generated matrix, inline tests), keeping going past failures. Exit non-zero if
# any failed.
test: build
    #!/usr/bin/env bash
    set -uo pipefail
    rc=0
    ../test/check-queries.sh {{ slug }} | tapview || rc=1
    ../test/parse-corpus.sh {{ slug }} | tapview || rc=1
    just validate-injections || rc=1
    ../test/gen-corpus.sh {{ slug }} | tapview || rc=1
    tree-sitter test --lib-path result/parser --lang-name {{ lang }} || rc=1
    exit "$rc"

# Parse every harvested GHC dump stream in $GHC_SRC (any IL banner). This only
# checks the banner/body split. `validate-injections` checks the dispatch.
parse-corpus:
    ../test/parse-corpus.sh {{ slug }} | tapview

# End-to-end injection check: split each harvested dump stream into its
# banner-delimited sections, classify each with injections.scm's own dispatch
# table, and parse it with the dispatched member grammar (asserting no errors
# beyond the documented known gaps). Needs the member parsers, so build them.
validate-injections:
    nix build ..#tree-sitter-ghc-core -o ../tree-sitter-ghc-core/result
    nix build ..#tree-sitter-ghc-stg -o ../tree-sitter-ghc-stg/result
    nix build ..#tree-sitter-ghc-cmm -o ../tree-sitter-ghc-cmm/result
    ../test/validate-injections.sh | tapview

# Ephemeral coverage check: generate a mixed multi-IL stream with GHC into a
# temp dir, parse it, report errors, tear down (nothing committed, see
# test/gen-corpus.sh).
gen-corpus: build
    ../test/gen-corpus.sh {{ slug }} | tapview
