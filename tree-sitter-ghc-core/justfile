default: test

# Run the inline unit tests for this grammar. The grammar currently models the
# -dsuppress-all structural surface, so the harvested $GHC_SRC corpus (default
# format: types + IdInfo + coercions) is not yet covered -- `parse-corpus` and
# `gen-corpus` report progress toward it.
test: build
    tree-sitter test --lib-path result/parser --lang-name ghc_core

# Parse every harvested Tidy Core .stderr in $GHC_SRC (not yet a clean gate --
# expect failures until type/IdInfo/coercion coverage lands).
parse-corpus:
    ../test/parse-corpus.sh ghc-core | tapview

# Ephemeral coverage check: generate a comprehensive dump-flag matrix with GHC
# into a temp dir, parse it, report errors, and tear it down (nothing committed;
# see test/gen-corpus.sh). Needs a GHC compiler, so it's not part of `test`.
gen-corpus: build
    ../test/gen-corpus.sh ghc-core

# Build the grammar via the nix flake (buildGrammar runs generate internally).
build:
    nix build ..#tree-sitter-ghc-core

# Check grammar for errors without building a result symlink.
check:
    nix build ..#tree-sitter-ghc-core --no-link

# Format the grammar file (mode: write|check)
fmt mode="write":
    prettier --{{ mode }} grammar.js

# Clean build artifacts
clean:
    rm -rf ghc_core.so result

# Generate src/parser.c locally (needed by highlight).
generate:
    tree-sitter generate

# Parse a file and print AST
parse file: build
    tree-sitter parse --lib-path result/parser --lang-name ghc_core {{ file }}

# Show syntax highlighting for a file
highlight file: generate
    tree-sitter highlight {{ file }}
