lang := "ghc_core"
slug := "ghc-core"

# Run recipe lines under bash with pipefail so a gate script's non-zero exit
# propagates through `| tapview` (the script, not tapview, decides pass/fail).
set shell := ["bash", "-o", "pipefail", "-c"]

# Shared build/check/fmt/clean/generate/parse/highlight recipes.
import 'common/recipes.just'

default: test

# Full gate suite (queries, harvested-corpus gate, generated matrix, inline
# tests). Shared flow is common/recipes.just `_il-test`. The harvest is a
# clean gate (0 ERROR/MISSING), coarse-soup leniency for IdInfo/coercions is
# allowed but no errors are emitted.
test: _il-test

# Parse every harvested Tidy Core .stderr in $GHC_SRC (a clean gate, also run by
# `test`). Single-pass Tidy Core only. Multi-dump captures are the container's.
parse-corpus:
    ../test/runners/parse-corpus.sh {{ slug }} | tapview

# Generate the comprehensive dump-flag matrix with GHC into a temp dir, parse
# each as a TAP suite, and tear it down (nothing committed, see
# test/runners/gen-corpus.sh). Needs a GHC compiler. Run by `test`.
gen-corpus: build
    ../test/runners/gen-corpus.sh {{ slug }} | tapview

# Like gen-corpus but across every flake `ghcVersions` GHC. Opt-in, NOT run by
# `test`/CI. Heavy (pulls each GHC closure).
gen-corpus-all: build
    ../test/runners/gen-corpus.sh {{ slug }} all | tapview
