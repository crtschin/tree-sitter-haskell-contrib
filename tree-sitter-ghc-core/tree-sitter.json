{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "ghc_core",
      "camelcase": "GhcCore",
      "title": "GHC Core",
      "scope": "source.ghc_core",
      "file-types": [
        "dump-simpl"
      ],
      "injection-regex": "^ghc[-_]?core$",
      "highlights": "queries/helix/highlights.scm",
      "class-name": "TreeSitterGhcCore"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for GHC Core dumps.",
    "authors": [
      {
        "name": "Curtis Chin Jen Sem",
        "email": "csochinjensem@gmail.com",
        "url": "https://crtschin.com/"
      }
    ],
    "links": {
      "repository": "https://github.com/crtschin/tree-sitter-haskell-contrib"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
