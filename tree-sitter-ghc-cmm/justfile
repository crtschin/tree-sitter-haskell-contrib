lang := "ghc_cmm"
slug := "ghc-cmm"

# Shared build/check/fmt/clean/generate/parse/highlight recipes.
import 'common/recipes.just'

default: test

# Run the inline unit tests and parse the Cmm-dump corpus for this grammar.
test: build check-queries parse-corpus
    tree-sitter test --lib-path result/parser --lang-name {{ lang }}

# Parse every harvested Cmm dump (`Output Cmm` / `Cmm produced by codegen`
# banner) in $GHC_SRC -- a clean gate (0 ERROR/MISSING), also run by `test`.
parse-corpus:
    ../test/parse-corpus.sh {{ slug }} | tapview

# Ephemeral coverage check: generate Cmm dumps with GHC into a temp dir, parse
# them, report errors, tear down (nothing committed; see test/gen-corpus.sh).
gen-corpus: build
    ../test/gen-corpus.sh {{ slug }}
