lang := "ghc_stg"
slug := "ghc-stg"

# Run recipe lines under bash with pipefail so a gate script's non-zero exit
# propagates through `| tapview` (the script, not tapview, decides pass/fail).
set shell := ["bash", "-o", "pipefail", "-c"]

# Shared build/check/fmt/clean/generate/parse/highlight recipes.
import 'common/recipes.just'

default: test

# Full gate suite (queries, harvested-corpus gate, generated matrix, inline
# tests); the shared flow is common/recipes.just `_il-test`.
test: _il-test

# Parse every harvested single-section STG dump in $GHC_SRC (a clean gate, also
# run by `test`). Multi-section captures are the container grammar's domain.
parse-corpus:
    ../test/parse-corpus.sh {{ slug }} | tapview

# Ephemeral coverage check: generate STG dumps with GHC into a temp dir, parse
# them, report errors, tear down (nothing committed, see test/gen-corpus.sh).
gen-corpus: build
    ../test/gen-corpus.sh {{ slug }} | tapview

# Like gen-corpus but across every flake `ghcVersions` GHC. Opt-in; NOT run by
# `test`/CI. Heavy (pulls each GHC closure).
gen-corpus-all: build
    ../test/gen-corpus.sh {{ slug }} all | tapview
