{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "cabal",
      "camelcase": "Cabal",
      "title": "Cabal",
      "scope": "source.cabal",
      "file-types": [
        "cabal"
      ],
      "injection-regex": "^cabal$",
      "highlights": "queries/helix/highlights.scm",
      "class-name": "TreeSitterCabal"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Cabal grammar for tree-sitter",
    "authors": [
