      },
      {
        "name": "Ananda Umamil",
        "email": "zweimach@zweimach.org",
        "url": "https://zweimach.org"
      },
      {
        "name": "Curtis Chin Jen Sem",
        "email": "csochinjensem@gmail.com",
        "url": "https://crtschin.com/"
      }
    ],
    "links": {
      "repository": "https://github.com/crtschin/tree-sitter-cabal"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
