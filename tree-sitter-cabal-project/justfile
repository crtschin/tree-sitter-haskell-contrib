lang := "cabal_project"
slug := "cabal-project"

# Run recipe lines under bash with pipefail so a gate script's non-zero exit
# propagates through `| tapview` (the script, not tapview, decides pass/fail).
set shell := ["bash", "-o", "pipefail", "-c"]

# Shared build/check/fmt/clean/generate/parse/highlight recipes.
import 'common/recipes.just'

default: test

# Run every suite to completion, keeping going past failures. Exit non-zero if
# any failed.
test: build
    #!/usr/bin/env bash
    set -uo pipefail
    rc=0
    ../test/runners/check-queries.sh {{ slug }} | tapview || rc=1
    ../test/runners/parse-corpus.sh {{ slug }} | tapview || rc=1
    ../test/runners/extract-golden.sh {{ slug }} | tapview || rc=1
    tree-sitter test --lib-path result/parser --lang-name {{ lang }} || rc=1
    exit "$rc"

# Parse every cabal.project / *.project file across the configured corpora.
parse-corpus:
    ../test/runners/parse-corpus.sh {{ slug }} | tapview

# Profile parsing the corpus and emit flamegraph-{{ slug }}.svg at the repo root.
flamegraph:
    ../test/perf/flamegraph-corpus.sh {{ slug }} ../flamegraph-{{ slug }}.svg

# Benchmark parsing the corpus with hyperfine.
bench:
    ../test/perf/bench-corpus.sh {{ slug }}

# Profile parsing the corpus under valgrind (tool = callgrind | cachegrind |
# memcheck | massif). Emits valgrind-{{ slug }}.{out,txt} at the repo root.
valgrind tool="callgrind":
    ../test/perf/valgrind-corpus.sh {{ slug }} ../valgrind-{{ slug }} --tool={{ tool }}

# Parse the corpus with -DSCANNER_STATS so the scanner emits a one-line
# [scanner-stats] call-rate report on stderr. Uses `tree-sitter parse
# --rebuild` to force a fresh compile with the flag, then a second --rebuild
# without the flag to restore an uninstrumented .so in the cache for normal runs.
stats: generate
    #!/usr/bin/env bash
    set -euo pipefail
    mapfile -t files < <(../test/files/{{ slug }}-files.sh)
    CFLAGS="-DSCANNER_STATS" tree-sitter parse --quiet --rebuild "${files[@]}" >/dev/null
    tree-sitter parse --quiet --rebuild "${files[0]}" >/dev/null 2>&1
