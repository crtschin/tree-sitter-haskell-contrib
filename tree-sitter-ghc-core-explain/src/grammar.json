{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "ghc_core_explain",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "_entry"
          },
          {
            "type": "SYMBOL",
            "name": "_newline"
          }
        ]
      }
    },
    "_entry": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "rule_firing"
        },
        {
          "type": "SYMBOL",
          "name": "inlining"
        },
        {
          "type": "SYMBOL",
          "name": "iterations"
        },
        {
          "type": "SYMBOL",
          "name": "total_ticks"
        },
        {
          "type": "SYMBOL",
          "name": "tick_category"
        }
      ]
    },
    "_newline": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "\\r?\\n"
      }
    },
    "rule_firing": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "Rule fired:"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "rule_name"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "provenance",
              "content": {
                "type": "SYMBOL",
                "name": "provenance"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "provenance": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "builtin"
            },
            {
              "type": "SYMBOL",
              "name": "module"
            }
          ]
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "builtin": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "STRING",
          "value": "BUILTIN"
        }
      }
    },
    "module": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[A-Z][A-Za-z0-9_'.]*"
      }
    },
    "inlining": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "Inlining done:"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "name",
              "content": {
                "type": "SYMBOL",
                "name": "inlined_id"
              }
            },
            {
              "type": "FIELD",
              "name": "detail",
              "content": {
                "type": "SYMBOL",
                "name": "detail"
              }
            }
          ]
        }
      ]
    },
    "iterations": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "Simplifier"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "TOKEN",
              "content": {
                "type": "PATTERN",
                "value": "[^\\r\\n]+"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "total_ticks": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "Total ticks:"
        },
        {
          "type": "FIELD",
          "name": "count",
          "content": {
            "type": "SYMBOL",
            "name": "number"
          }
        }
      ]
    },
    "tick_category": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "count",
          "content": {
            "type": "SYMBOL",
            "name": "number"
          }
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "category_name"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "number"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "tick_detail"
          }
        }
      ]
    },
    "tick_detail": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_indent"
        },
        {
          "type": "FIELD",
          "name": "count",
          "content": {
            "type": "SYMBOL",
            "name": "number"
          }
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "detail_name"
          }
        }
      ]
    },
    "number": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[0-9]+"
      }
    },
    "category_name": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[A-Z][A-Za-z0-9_']*"
      }
    },
    "detail_name": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^\\r\\n]+"
      }
    },
    "_indent": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "\\r?\\n[ \\t]+"
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t\\f]"
    }
  ],
  "conflicts": [
    [
      "tick_category"
    ]
  ],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "rule_name"
    },
    {
      "type": "SYMBOL",
      "name": "inlined_id"
    },
    {
      "type": "SYMBOL",
      "name": "detail"
    }
  ],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}